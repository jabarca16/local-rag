# Servidor
PORT=8000

# Embeddings
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Chroma (legacy — kept for rollback reference)
CHROMA_PATH=./data/chroma
CHROMA_COLLECTION=rag_docs

# Qdrant
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# Redis / Celery
REDIS_URL=redis://redis:6379/0

# Seguridad
JWT_SECRET=cambia-esto-por-un-secreto-seguro
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# Admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=cambia-esto

# MCP (API key para acceso remoto al endpoint /mcp/sse)
MCP_API_KEY=cambia-esto-por-una-clave-segura

# Service key para llamadas internas MCP → FastAPI (solo lectura)
SERVICE_API_KEY=cambia-esto-por-otra-clave-segura
